<header>
    <h1>Anotações</h1>
    
</header>
<div id="popup-anot">
        <form action="/anot" method="post">
            <input type="text" name="nome" id="nome" required maxlength="100"placeholder="Nome">
            <textarea name="anotacao" id="anotacao" placeholder="Anotação"></textarea>
            <button type="submit">Enviar</button>
        </form>
    </div>
<main> 
    {{#each postanot}}
    <div>
    <h2>Acionador: {{nome_anotador}}</h2>
    <p>{{anotacao}}</p>
    <a href="/del/{{idanotacao}}"><button>deletar</button></a>
    </div>
    {{/each}}
</main>
